% ============================================================
%  beamerinnerthemehorixon.sty  —  Inner sub-theme
%  Controls: title page, section pages, bullet styles, blocks
%
%  Title page layout (full-bleed split):
%    LEFT  62%  horixonnavy   — accent bar, title, subtitle, author, institute strip
%    RIGHT 38%  horixoncream  — institution logo, faint vertical grid
% ============================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerinnerthemehorixon}[2026/03/11 Horixon Inner Theme]

\mode<presentation>

\usepackage{tikz}
\usetikzlibrary{calc, positioning, shapes.geometric, backgrounds, fadings}

% ---- Bullet / item symbols ----------------------------------
\setbeamertemplate{items}[circle]
\setbeamertemplate{sections/subsections in toc}[circle]

% ---- QED symbol ---------------------------------------------
\setbeamertemplate{qed symbol}{\textcolor{horixonaccent}{$\blacksquare$}}

% ---- Navigation symbols: suppress ---------------------------
\setbeamertemplate{navigation symbols}{}

% ================================================================
%  TITLE PAGE
% ================================================================
\defbeamertemplate*{title page}{horixon}[1][]
{
  \begin{tikzpicture}[remember picture, overlay]

    % ── Backgrounds ──────────────────────────────────────────────

    % Right panel — pale cream base
    \fill[horixoncream!40!white]
      (current page.south west) rectangle (current page.north east);

    % Left panel — deep navy
    \fill[horixonnavy]
      (current page.south west)
      rectangle ([xshift=0.62\paperwidth] current page.north west);

    % ── Left panel ───────────────────────────────────────────────

    % Top accent bar
    \fill[horixonaccent]
      (current page.north west)
      rectangle
      ([xshift=0.62\paperwidth, yshift=-0.018\paperheight]
        current page.north west);

    % Vertical seam rule at panel boundary
    \draw[horixonaccent, line width=1.5pt]
      ([xshift=0.62\paperwidth] current page.south west)
      -- ([xshift=0.62\paperwidth] current page.north west);

    % Small filled square marker at title baseline
    \fill[horixonaccent]
      ([xshift=0.044\paperwidth, yshift=-0.185\paperheight]
        current page.north west)
      rectangle ++(0.18cm, 0.18cm);

    % Institute footer strip
    \fill[horixondark]
      (current page.south west)
      rectangle
      ([xshift=0.52\paperwidth, yshift=0.18\paperheight]
        current page.south west);

    % Separator rule above institute strip
    \draw[horixonaccent!50!horixondark, line width=0.4pt]
      ([xshift=0.044\paperwidth, yshift=0.18\paperheight]
        current page.south west)
      -- ++(0.4\paperwidth, 0);

    % ── Right panel ──────────────────────────────────────────────

    % Institution logo
    \node[anchor=north west] at
      ([xshift=0.72\paperwidth, yshift=-0.06\paperheight]
        current page.north west)
      {\includegraphics[width=0.22\paperwidth, height=0.42\paperheight,
        keepaspectratio=true]{assets/logos/knustnims.png}};

    % Faint vertical rule grid
    \begin{scope}[horixondark, opacity=0.1, line width=0.3pt]
      \foreach \i in {1,...,8} {
        \draw
          ([xshift={0.535\paperwidth + \i * 0.052\paperwidth},
            yshift=0.02\paperheight] current page.south west)
          -- ++(0, 0.32\paperheight);
      }
    \end{scope}

    % Full-width bottom accent sliver
    \fill[horixonaccent]
      (current page.south west)
      rectangle ++(\paperwidth, 0.007\paperheight);

  \end{tikzpicture}%

  % ── Text nodes ───────────────────────────────────────────────
  \begin{tikzpicture}[remember picture, overlay]

    % Title
    \node[anchor=north west, text width=0.60\paperwidth,
          align=left, inner sep=0pt] at
      ([xshift=0.060\paperwidth, yshift=-0.167\paperheight]
        current page.north west)
      {{\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle}};

    % Rule under title
    \draw[horixonaccent, line width=0.5pt]
      ([xshift=0.062\paperwidth, yshift=-0.58\paperheight]
        current page.north west)
      -- ++(0.43\paperwidth, 0);

    % Subtitle
    \node[anchor=north west, text width=0.46\paperwidth,
          align=left, inner sep=0pt] at
      ([xshift=0.062\paperwidth, yshift=-0.61\paperheight]
        current page.north west)
      {%
        \ifx\insertsubtitle\empty\else
          {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}%
            \insertsubtitle}%
        \fi
      };

    % Author
    \node[anchor=north west, text width=0.46\paperwidth,
          align=left, inner sep=0pt] at
      ([xshift=0.062\paperwidth, yshift=-0.70\paperheight]
        current page.north west)
      {{\usebeamerfont{author}\usebeamercolor[fg]{author}\insertauthor}};

    % Institute — inside footer strip
    \node[anchor=north west, text width=0.46\paperwidth,
          align=center, inner sep=0pt] at
      ([xshift=0.012\paperwidth, yshift=-0.838\paperheight]
        current page.north west)
      {{\usebeamerfont{institute}\color{horixoncream}\insertinstitute}};

    % Date — bottom-right of right panel
    \node[anchor=south east, inner sep=0pt] at
      ([xshift=-0.044\paperwidth, yshift=0.022\paperheight]
        current page.south east)
      {{\usebeamerfont{date}\color{horixondark}\insertdate}};

  \end{tikzpicture}%
}

% ================================================================
%  SECTION PAGE
% ================================================================
\defbeamertemplate*{section page}{horixon}[1][]
{
  \begin{tikzpicture}[remember picture, overlay]
    \fill[horixonnavy]   (current page.south west) rectangle (current page.north east);
    \fill[horixonaccent] (current page.north west) rectangle +(\paperwidth, -0.18cm);
    \fill[horixonaccent] (current page.south west) rectangle +(\paperwidth,  0.12cm);
    \fill[horixondark]
      ([xshift=-0.01cm] current page.south west) rectangle ++(0.25cm, \paperheight);
    \fill[horixonaccent]
      ([xshift=-0.01cm] current page.south west) rectangle ++(0.08cm, \paperheight);
  \end{tikzpicture}
  \vfill
  \begin{center}
    \textcolor{horixoncream}{\Large\bfseries\insertsectionnumber.~\insertsection}
  \end{center}
  \vfill
}

% ================================================================
%  BLOCK TEMPLATES  (rounded)
% ================================================================
\setbeamertemplate{block begin}{
  \vskip.1cm
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm]{block title}
    \usebeamerfont{block title}\insertblocktitle
  \end{beamercolorbox}
  \nointerlineskip
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm, vmode]{block body}
    \usebeamerfont{block body}
}
\setbeamertemplate{block end}{
  \end{beamercolorbox}\vskip.1cm
}

\setbeamertemplate{block alerted begin}{
  \vskip.1cm
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm]{block title alerted}
    \usebeamerfont{block title}\insertblocktitle
  \end{beamercolorbox}
  \nointerlineskip
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm, vmode]{block body alerted}
    \usebeamerfont{block body}
}
\setbeamertemplate{block alerted end}{
  \end{beamercolorbox}\vskip.1cm
}

\setbeamertemplate{block example begin}{
  \vskip.1cm
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm]{block title example}
    \usebeamerfont{block title}\insertblocktitle
  \end{beamercolorbox}
  \nointerlineskip
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm, vmode]{block body example}
    \usebeamerfont{block body}
}
\setbeamertemplate{block example end}{
  \end{beamercolorbox}\vskip.1cm
}

\mode<all>
