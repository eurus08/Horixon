% ============================================================
%  beamerinnerthemehorixon.sty  —  Inner sub-theme
%  Controls: title page, section pages, bullet styles, blocks
%  Title page: bold full-bleed design with layered geometric
%  panels and a central text card — no diagram clutter.
% ============================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerinnerthemehorixon}[2024/01/01 HPC Inner Theme]

\mode<presentation>

\usepackage{tikz}
\usetikzlibrary{calc, positioning, shapes.geometric, backgrounds, fadings}

% ---- Bullet / item symbols ----------------------------------
\setbeamertemplate{items}[circle]
\setbeamertemplate{sections/subsections in toc}[circle]

% ---- QED symbol: small cyan square -------------------------
\setbeamertemplate{qed symbol}{\textcolor{horixonaccent}{$\blacksquare$}}

% ---- Navigation symbols: suppress ---------------------------
\setbeamertemplate{navigation symbols}{}

% ================================================================
%  TITLE PAGE
%  Design: dark navy base, large angled cyan band cutting across
%  the bottom-right, a white text card anchored centre-left,
%  and a cluster of faint concentric parallelograms top-right
%  for a clean geometric/technical feel.
% ================================================================
\defbeamertemplate*{title page}{horixon}[1][]
{
  \begin{tikzpicture}[remember picture, overlay]

    % ── 1. Full background ──────────────────────────────────
    \fill[horixonnavy] (current page.south west) rectangle (current page.north east);

    % ── 2. Large angled warm slab (bottom-right wedge) ──────
    \fill[horixonaccent!70!horixonnavy]
      (current page.south east)
      -- ++(-\paperwidth, 0)
      -- ++(0.62\paperwidth, 0.38\paperheight)
      -- cycle;

    % ── 3. Lighter cream triangle layered on top (smaller) ──
    \fill[horixoncream!80!horixonaccent]
      (current page.south east)
      -- ++(-0.52\paperwidth, 0)
      -- ++(0, 0.28\paperheight)
      -- cycle;

    % ── 4. Parallelogram accent stack (top-right, decorative)
    \begin{scope}[opacity=0.15, shift={(current page.north east)},
                  xshift=-0.5cm, yshift=-0.4cm]
      \foreach \i in {1,...,6} {
        \fill[horixonaccent, rotate=-18]
          ({-\i*0.9cm}, {-\i*0.5cm})
          rectangle ++({0.7cm}, {3.2cm - \i*0.28cm});
      }
    \end{scope}

    % ── 5. Horizontal rule strip below headline area ─────────
    \fill[horixonaccent] (current page.north west)
      rectangle ++(\paperwidth, -0.20cm);

    % ── 6. Subtle grid dots (top-left quadrant) ──────────────
    \begin{scope}[opacity=0.10]
      \foreach \x in {0.6, 1.2, ..., 5.4} {
        \foreach \y in {0.4, 0.9, ..., 3.8} {
          \fill[horixonaccent] ([xshift=\x cm, yshift=-\y cm]
            current page.north west) circle (0.6pt);
        }
      }
    \end{scope}

    % ── 7. Thin vertical accent bar (left-side) ──────────────
    \fill[horixonaccent]
      (current page.south west) rectangle ++(0.22cm, \paperheight);

    % ── 8. Soft circle behind text area ──────────────────────
    \fill[horixondark, opacity=0.55]
      ([xshift=5.8cm, yshift=0.5cm] current page.west)
      circle (3.4cm);

  \end{tikzpicture}%

  % ── 9. Text card (positioned with minipage, sits over art) ──
  \vspace{-\paperheight}%
  \vspace{1.05cm}%
  \hspace{0.65cm}%
  \begin{minipage}[t]{0.60\paperwidth}
    \raggedright

    % Title
    {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par}

    \vspace{0.18cm}
    % Cyan rule with inset dot
    \begin{tikzpicture}
      \draw[horixonaccent, line width=0.6pt] (0,0) -- (0.55\linewidth, 0);
      \fill[horixonaccent] (0,0) circle (1.6pt);
    \end{tikzpicture}\par
    \vspace{0.14cm}

    % Subtitle
    \ifx\insertsubtitle\empty\else
      {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}
      \vspace{0.25cm}
    \fi

    % Author
    {\usebeamerfont{author}\usebeamercolor[fg]{author}\insertauthor\par}
    \vspace{0.08cm}

    % Institute
    {\usebeamerfont{institute}\usebeamercolor[fg]{institute}\insertinstitute\par}
    \vspace{0.12cm}

    % Date
    {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate\par}
  \end{minipage}
}

% ================================================================
%  SECTION PAGE  (shown when \sectionpage is called)
% ================================================================
\defbeamertemplate*{section page}{horixon}[1][]
{
  \begin{tikzpicture}[remember picture, overlay]
    \fill[horixonnavy] (current page.south west) rectangle (current page.north east);
    \fill[horixonaccent] (current page.north west) rectangle +(\paperwidth, -0.18cm);
    \fill[horixonaccent] (current page.south west) rectangle +(\paperwidth,  0.12cm);
    \fill[horixondark]
      ([xshift=-0.01cm] current page.south west) rectangle
      ++(0.25cm, \paperheight);
    \fill[horixonaccent]
      ([xshift=-0.01cm] current page.south west) rectangle
      ++(0.08cm, \paperheight);
  \end{tikzpicture}
  \vfill
  \begin{center}
    \textcolor{horixoncream}{\Large\bfseries\insertsectionnumber.~\insertsection}
  \end{center}
  \vfill
}

% ================================================================
%  BLOCK TEMPLATES  (rounded, Boadilla-inspired)
% ================================================================
\setbeamertemplate{block begin}{
  \vskip.1cm
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm]{block title}
    \usebeamerfont{block title}\insertblocktitle
  \end{beamercolorbox}
  \nointerlineskip
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm,
      vmode]{block body}
    \usebeamerfont{block body}
}
\setbeamertemplate{block end}{
  \end{beamercolorbox}
  \vskip.1cm
}

\setbeamertemplate{block alerted begin}{
  \vskip.1cm
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm]{block title alerted}
    \usebeamerfont{block title}\insertblocktitle
  \end{beamercolorbox}
  \nointerlineskip
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm,
      vmode]{block body alerted}
    \usebeamerfont{block body}
}
\setbeamertemplate{block alerted end}{
  \end{beamercolorbox}
  \vskip.1cm
}

\setbeamertemplate{block example begin}{
  \vskip.1cm
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm]{block title example}
    \usebeamerfont{block title}\insertblocktitle
  \end{beamercolorbox}
  \nointerlineskip
  \begin{beamercolorbox}[rounded=true, shadow=false,
      leftskip=0.4cm, rightskip=0.4cm, sep=0.2cm,
      vmode]{block body example}
    \usebeamerfont{block body}
}
\setbeamertemplate{block example end}{
  \end{beamercolorbox}
  \vskip.1cm
}

\mode<all>
